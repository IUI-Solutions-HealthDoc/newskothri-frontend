# Copy to `.env.local` for local development (never commit `.env.local`).
#
# ── Local dev ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:5280

# Leave empty: Next.js proxies `/api/*` and `/uploads/*` to backend :5050 (see next.config.ts).
NEXT_PUBLIC_API_ORIGIN=

# Optional — R2 public host for next/image
# NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Server-side fetches (metadata, sitemap). Defaults to http://127.0.0.1:5050 when unset.
# INTERNAL_API_URL=http://127.0.0.1:5050

# Google OAuth (readers). Must be the **Web application** client ID (ends with .apps.googleusercontent.com).
# Must match backend GOOGLE_CLIENT_ID exactly. Authorized JS origins: http://localhost:5280, http://127.0.0.1:5280, production URL.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Analytics 4 (gtag.js). Omit locally to disable tracking during dev.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-0T86G58LY4

# ── Vercel production (required on Vercel — build fails if API/SITE missing) ──
# NEXT_PUBLIC_API_ORIGIN=https://your-api.up.railway.app
# NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
# INTERNAL_API_URL=https://your-api.up.railway.app
# NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=<same as backend GOOGLE_CLIENT_ID>
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-0T86G58LY4
# Redeploy web-next after any change. Railway CLIENT_URLS must include this site's https origin.

# ── YouTube channel stats (Shows page + video section) ─────────────────────
# Google Cloud → APIs & Services → enable "YouTube Data API v3" → create API key.
# Restrict key to YouTube Data API v3. Stats load from @NewsKothri by default.
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_HANDLE=NewsKothri

# ── Market snapshot (business articles sidebar / mobile strip) ───────────────
# Uses Yahoo Finance chart API — no API key required.

#Deployment commit -1
